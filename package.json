{
  "name": "syncless-cli",
  "version": "0.0.2",
  "description": "CLI for the Syncless Console API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "syncless": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm typecheck && pnpm test && pnpm build",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "syncless",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ACAne0320/syncless-cli.git"
  },
  "homepage": "https://github.com/ACAne0320/syncless-cli#readme",
  "bugs": {
    "url": "https://github.com/ACAne0320/syncless-cli/issues"
  },
  "license": "MIT",
  "packageManager": "pnpm@9.15.4",
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "conf": "^13.1.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  },
  "engines": {
    "node": ">=18"
  }
}
